container_commands:
  01_cron_setup:
    command: |
      # Clear old sendNotification.js entries
      crontab -l 2>/dev/null | grep -v sendNotification.js > temp_cron
      
      # INDIA (IST - Asia/Kolkata) - 10:30 AM and 7:00 PM IST
      echo "0 5 * * * TZ=Asia/Kolkata /usr/bin/node /var/app/current/sendNotification.js IN --timezone=Asia/Kolkata >> /var/log/cron.log 2>&1" >> temp_cron
      echo "30 13 * * * TZ=Asia/Kolkata /usr/bin/node /var/app/current/sendNotification.js IN --timezone=Asia/Kolkata >> /var/log/cron.log 2>&1" >> temp_cron
      
      # USA (EST - America/New_York) - 10:30 AM and 7:00 PM EST
      echo "30 15 * * * TZ=America/New_York /usr/bin/node /var/app/current/sendNotification.js US --timezone=America/New_York >> /var/log/cron.log 2>&1" >> temp_cron
      echo "0 0 * * * TZ=America/New_York /usr/bin/node /var/app/current/sendNotification.js US --timezone=America/New_York >> /var/log/cron.log 2>&1" >> temp_cron
      
      # UK (GMT/BST - Europe/London) - 10:30 AM and 7:00 PM London time
      echo "30 10 * * * TZ=Europe/London /usr/bin/node /var/app/current/sendNotification.js GB --timezone=Europe/London >> /var/log/cron.log 2>&1" >> temp_cron
      echo "0 19 * * * TZ=Europe/London /usr/bin/node /var/app/current/sendNotification.js GB --timezone=Europe/London >> /var/log/cron.log 2>&1" >> temp_cron
      
      # CANADA (EST - America/Toronto) - 10:30 AM and 7:00 PM EST
      echo "30 15 * * * TZ=America/Toronto /usr/bin/node /var/app/current/sendNotification.js CA --timezone=America/Toronto >> /var/log/cron.log 2>&1" >> temp_cron
      echo "0 0 * * * TZ=America/Toronto /usr/bin/node /var/app/current/sendNotification.js CA --timezone=America/Toronto >> /var/log/cron.log 2>&1" >> temp_cron
      
      # AUSTRALIA (AEDT - Australia/Sydney) - 10:30 AM and 7:00 PM Sydney time
      echo "30 23 * * * TZ=Australia/Sydney /usr/bin/node /var/app/current/sendNotification.js AU --timezone=Australia/Sydney >> /var/log/cron.log 2>&1" >> temp_cron
      echo "0 8 * * * TZ=Australia/Sydney /usr/bin/node /var/app/current/sendNotification.js AU --timezone=Australia/Sydney >> /var/log/cron.log 2>&1" >> temp_cron
      
      # DEFAULT - Send to all other countries (excluding the 5 above) at UTC 10:30 AM and 7:00 PM
      echo "30 10 * * * TZ=UTC /usr/bin/node /var/app/current/sendNotification.js DEFAULT --timezone=UTC >> /var/log/cron.log 2>&1" >> temp_cron
      echo "0 19 * * * TZ=UTC /usr/bin/node /var/app/current/sendNotification.js DEFAULT --timezone=UTC >> /var/log/cron.log 2>&1" >> temp_cron

      echo "*/5 * * * * TZ=UTC /usr/bin/node /var/app/current/pauselink.js DEFAULT --timezone=UTC >> /var/log/cron.log 2>&1" >> temp_cron 

      # Apply crontab
      crontab temp_cron
      rm temp_cron
      
      # Create log file if it doesn't exist
      touch /var/log/cron.log
      chmod 666 /var/log/cron.log
      
      # Restart cron service
      service cron restart
      
      echo "✅ Cron jobs configured successfully!"
      echo "📋 Scheduled notifications:"
      echo "   🇮🇳 India (IN): 10:30 AM & 7:00 PM IST"
      echo "   🇺🇸 USA (US): 10:30 AM & 7:00 PM EST"
      echo "   🇬🇧 UK (GB): 10:30 AM & 7:00 PM GMT/BST"
      echo "   🇨🇦 Canada (CA): 10:30 AM & 7:00 PM EST"
      echo "   🇦🇺 Australia (AU): 10:30 AM & 7:00 PM AEDT"
      echo "   🌍 Other countries: 12:00 PM & 8:00 PM UTC"